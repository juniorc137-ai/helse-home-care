{
  "name": "home-care-app",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^3.9.1",
    "@noble/ciphers": "^1.2.1",
    "@noble/hashes": "^1.7.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/netinfo": "^11.4.1",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "immer": "^10.1.1",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.2",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-paper": "^5.13.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~57.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo",
    "resolver": "react-native-worklets/jest/resolver.js",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/__tests__/fixtures/",
      "<rootDir>/__tests__/testUtils.tsx"
    ],
    "moduleNameMapper": {
      "^immer$": "<rootDir>/node_modules/immer/dist/cjs/index.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 60,
        "branches": 60,
        "functions": 60,
        "lines": 60
      }
    }
  },
  "private": true
}
